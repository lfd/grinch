set -e

abs_srctree=$1
abs_output=$2

cat > "$abs_output/Makefile" <<EOF
# Automatically generated by $abs_srctree/Makefile: don't edit

this-makefile := \$(lastword \$(MAKEFILE_LIST))
abs_output    := \$(realpath \$(dir \$(this-makefile)))

MAKEFLAGS += --no-print-directory

.PHONY: __sub-make \$(MAKECMDGOALS)
\$(filter-out __all sub-make \$(this-makefile), \$(MAKECMDGOALS)) __all: sub-make
	@:
sub-make:
	@\$(MAKE) -C $abs_srctree O=\$(abs_output) \$(MAKECMDGOALS)
EOF

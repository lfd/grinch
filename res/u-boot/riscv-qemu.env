# Offset: 2 MiB
loadaddr=0x80200000
# Offset: 32 MiB
kernel_addr_r=0x82000000
# Offset: 32 MiB + 8 MiB
ramdisk_addr_r=0x82800000
# Size: 4 MiB
ramdisk_sz=0x400000

fdt_addr_r=0x83000000

preboot=setenv fdt_addr ${fdtcontroladdr}; fdt addr ${fdtcontroladdr};
bootcmd=run preboot;booti ${kernel_addr_r} ${ramdisk_addr_r}:${ramdisk_sz} ${fdt_addr}
bootdelay=0
